# Decentralend — example environment file.
# Copy to `.env` and fill in your values. `.env` is gitignored; this file is not.
# Never commit real values to this file.

# -----------------------------------------------------------------------------
# RPC endpoints
# -----------------------------------------------------------------------------

# Sepolia RPC endpoint. Get one from Alchemy, Infura, QuickNode, or any
# provider that supports Sepolia. Referenced via `--rpc-url sepolia` thanks
# to the [rpc_endpoints] block in foundry.toml.
SEPOLIA_RPC_URL=

# -----------------------------------------------------------------------------
# Block explorer
# -----------------------------------------------------------------------------

# Etherscan API key for contract verification on Sepolia.
# Get from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Deployer (Foundry keystore — no private key in env)
# -----------------------------------------------------------------------------

# Foundry keystore account name. Stored encrypted at ~/.foundry/keystores.
# Import once with:
#   cast wallet import <name> --interactive
# Then pass to forge as:
#   forge script script/Deploy.s.sol --rpc-url sepolia --account $ACCOUNT \
#     --sender $SENDER --broadcast --verify
ACCOUNT=

# Deployer address corresponding to the keystore above. Used as --sender
# when running forge script.
SENDER=
